#compdef xrandr-profile
# zsh completion for xrandr-profile
# Install as: <dir on $fpath>/_xrandr-profile
#         e.g. /usr/share/zsh/site-functions/_xrandr-profile

_xrandr_profile()
{
	local state

	_arguments -s \
		'(- *)--help[print help and exit]' \
		'(- *)--version[print version and exit]' \
		'--save=[save the current layout as NAME]:name:' \
		'--load=[load a saved profile]:profile:->matching' \
		'--delete=[delete a saved profile]:profile:->profiles' \
		'--list[list profiles matching current hardware]' \
		'--list-all[list all saved profiles]' \
		'--list-current[print the current active layout]' \
		'--watch[watch for hotplug changes and auto-apply]' \
		'--fallback=[auto-arrange unknown monitor sets]:mode:(horizontal vertical clone off)' \
		'--force[force apply profile]' \
		'--verbose[log actions to stderr]' \
		'--dry-run[run without applying anything]' \
		'--names[print only the profile names]'

	if [[ $state == profiles ]]; then
		local -a profiles
		profiles=(${(f)"$(xrandr-profile --list-all --names 2>/dev/null)"})
		compadd -a profiles
	elif [[ $state == matching ]]; then
		local -a profiles
		profiles=(${(f)"$(xrandr-profile --list --names 2>/dev/null)"})
		compadd -a profiles
	fi
}

_xrandr_profile "$@"
